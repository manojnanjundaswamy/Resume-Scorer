# ─────────────────────────────────────────────────────────────────────────────
# ResumeScore AI — Spring Boot Backend
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_me_with_a_32_plus_char_random_string
JWT_EXPIRATION_MS=86400000   # 24 hours in milliseconds

# ── AI Provider ───────────────────────────────────────────────────────────────
# Choose one: CLAUDE | GEMINI | OPENAI | OPENROUTER
ACTIVE_AI_PROVIDER=CLAUDE

ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=resumescorer-uploads

# ── Google Sign-In ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Credits ───────────────────────────────────────────────────────────────────
NEW_USER_FREE_CREDITS=3
