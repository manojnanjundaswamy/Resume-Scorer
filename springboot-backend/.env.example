# ResumeScore AI - Spring Boot Backend
# Copy this file to .env and fill in local values.
# Never commit .env.

# Database - matches docker-compose.yml
DATABASE_URL=jdbc:postgresql://localhost:5432/resumescorer
DATABASE_USERNAME=resumescorer
DATABASE_PASSWORD=resumescorer_dev

# JWT - use a long random value outside local development
JWT_SECRET=replace_me_with_a_32_plus_char_random_string
JWT_EXPIRATION_MS=86400000

# AI provider
# Use MOCK for first-time setup without an external AI key.
# Other valid values: CLAUDE, GEMINI, OPENAI, OPENROUTER
ACTIVE_AI_PROVIDER=MOCK
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Local S3-compatible storage through MinIO
S3_ENDPOINT=http://localhost:9000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=resumescorer-files

# Google Sign-In
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Razorpay payments - optional for local non-payment testing
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Credits
NEW_USER_FREE_CREDITS=3
CREDITS_PER_ANALYSIS=1
