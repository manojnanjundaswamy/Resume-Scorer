# ResumeScore AI Web App
# Copy this file to .env.local and fill in local values.
# Never commit .env.local.

# Google OAuth Client ID, web application type.
# The backend .env file must use the same client ID.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Leave empty in local dev. Vite proxies /api to http://localhost:8080.
# Set this to the deployed backend origin for production builds.
VITE_API_URL=
